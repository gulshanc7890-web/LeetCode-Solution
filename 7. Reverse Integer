class Solution:
    def reverse(self, x: int) -> int:
        is_negative=False
        if(x<0):
            is_negative=True
        n=abs(x)
        rev=0
        while(n>0):
                r=n%10
                rev=rev*10+r
                n=n//10
        if rev<(-2**31) or rev>(2**31-1):
            return 0
        return -rev if is_negative else rev

        
