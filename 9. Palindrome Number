class Solution:
    def isPalindrome(self, x: int) -> bool:
        num=x
        is_negative=False
        if(num<0):
            is_negative=True
        n=abs(num)
        rev=0
        while(n>0):
          r=n%10
          rev=rev*10+r
          n=n//10
        if(rev==num):
            return True
        else:
            return False        


        
